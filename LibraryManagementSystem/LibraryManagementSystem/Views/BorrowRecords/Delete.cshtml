@model LibraryManagementSystem.Models.BorrowRecord

@{
    ViewData["Title"] = "Delete Transaction";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Delete Record</h2>
        </div>

        <div class="tech-card border-top border-danger border-5">
            <div class="text-center mb-5">
                <div class="bg-surface p-4 border border-danger d-inline-block shadow-lg mb-4">
                    <i class="fas fa-history fa-4x text-danger animate-pulse"></i>
                </div>
                <h3 class="text-white">Delete Transaction Log?</h3>
                <p class="text-muted">Are you sure you want to permanently remove this record?</p>
            </div>

            <div class="bg-surface p-4 border border-tech mb-5 shadow-sm">
                <div class="bg-white p-3 border border-danger mb-3 shadow-sm rounded">
                    <div class="text-muted small uppercase fw-bold mb-1">Book Title</div>
                    <div class="text-dark fw-bold">@Model.Book?.Title</div>
                </div>
                <div class="d-flex justify-content-between align-items-center px-2">
                    <div>
                        <div class="text-primary small fw-bold">Borrower</div>
                        <div class="text-white">@Model.User?.FullName</div>
                    </div>
                    <div class="text-end">
                        <div class="text-primary small fw-bold">Issue Date</div>
                        <div class="text-muted">@Model.BorrowDate.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="BorrowId" />
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-danger flex-grow-1 shadow-sm">
                        Confirm Deletion
                    </button>
                    <a asp-action="Index" class="btn btn-outline-primary px-4">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
