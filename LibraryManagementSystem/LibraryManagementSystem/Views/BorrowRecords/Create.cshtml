@model LibraryManagementSystem.Models.BorrowRecord

@{
    ViewData["Title"] = "Issue New Loan";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Record Book Loan</h2>
        </div>

        <div class="tech-card border-top border-primary border-5">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                
                <div class="row">
                    <div class="col-md-12 mb-4">
                        <div class="form-group">
                            <label asp-for="BookId" class="form-label text-accent fw-bold"><i class="fas fa-book me-1"></i> Selection of Book</label>
                            <select asp-for="BookId" class="form-control" asp-items="ViewBag.BookId">
                                <option value="">-- Select Book --</option>
                            </select>
                            <span asp-validation-for="BookId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-12 mb-4">
                        <div class="form-group">
                            <label asp-for="UserId" class="form-label text-accent fw-bold"><i class="fas fa-user me-1"></i> Selection of Borrower</label>
                            <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId">
                                <option value="">-- Select Member --</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="BorrowDate" class="form-label text-accent fw-bold"><i class="far fa-calendar-alt me-1"></i> Issue Date</label>
                            <input asp-for="BorrowDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="BorrowDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="ReturnDate" class="form-label text-accent fw-bold"><i class="far fa-calendar-check me-1"></i> Due Date</label>
                            <input asp-for="ReturnDate" type="date" class="form-control" value="@DateTime.Now.AddDays(14).ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="ReturnDate" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 pt-4 border-top border-tech mt-4">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        Issue Book
                    </button>
                    <a asp-action="Index" class="btn btn-outline-primary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
