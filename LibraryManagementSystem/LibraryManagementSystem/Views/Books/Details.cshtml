@model LibraryManagementSystem.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Book Details</h2>
        </div>

        <div class="tech-card border-top border-primary border-5">
            <div class="row">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <div class="bg-surface p-4 border border-primary d-inline-block shadow-lg">
                        <i class="fas fa-microchip fa-5x text-primary"></i>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="mb-4">
                        <label>Title</label>
                        <h3 class="text-white">@Model.Title</h3>
                        <p class="text-muted">Author: @Model.Author</p>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-sm-6">
                            <label>Category</label>
                            <p class="text-white"><i class="fas fa-tag text-primary me-2"></i>@Model.Category</p>
                        </div>
                        <div class="col-sm-6">
                            <label>ISBN Number</label>
                            <p class="text-white"><i class="fas fa-barcode text-primary me-2"></i>#@Model.Isbn</p>
                        </div>
                        <div class="col-sm-6">
                            <label>Status</label>
                            <p>
                                @if (Model.Quantity > 0)
                                {
                                    <span class="text-primary"><i class="fas fa-check me-2"></i>In Stock (@Model.Quantity units)</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="fas fa-times me-2"></i>Out of Stock</span>
                                }
                            </p>
                        </div>
                    </div>

                        <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-primary flex-grow-1">
                            Edit Book
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.BookId" class="btn btn-outline-danger">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
