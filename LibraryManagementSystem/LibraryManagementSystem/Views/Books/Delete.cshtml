@model LibraryManagementSystem.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="glass-card border-top border-5 border-danger">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Delete Book</h2>
        </div>
        <p class="text-muted">Are you sure you want to delete this book from the collection?</p>
            </div>

            <div class="bg-surface p-4 border border-tech mb-5 shadow-sm">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <i class="fas fa-book-dead fa-3x text-muted opacity-25"></i>
                    </div>
                    <div class="col">
                        <div class="text-primary small mb-1 fw-bold">Book Title</div>
                        <h5 class="text-white mb-0">@Model.Title</h5>
                        <p class="text-muted small mb-0">ISBN: #@Model.Isbn</p>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="BookId" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-danger flex-grow-1 shadow-sm">
                        <i class="fas fa-trash-alt me-2"></i>Confirm Removal
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel Action</a>
                </div>
            </form>
        </div>
    </div>
</div>
