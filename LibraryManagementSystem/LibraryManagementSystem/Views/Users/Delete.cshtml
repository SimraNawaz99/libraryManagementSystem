@model LibraryManagementSystem.Models.User

@{
    ViewData["Title"] = "Remove User Account";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Delete User Account</h2>
        </div>
        <p class="text-muted px-lg-5">Confirm deactivation of <strong>@Model.FullName</strong>. This record will be permanently purged.</p>

                <div>
                    <div class="text-primary small mb-1 fw-bold">Target User</div>
                    <h5 class="text-white mb-0">@Model.FullName</h5>
                    <p class="text-muted small mb-0">Username: @@@Model.Username</p>
                </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="UserId" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-danger flex-grow-1 shadow-sm">
                        <i class="fas fa-user-minus me-2"></i>Delete Member Record
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Go Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
