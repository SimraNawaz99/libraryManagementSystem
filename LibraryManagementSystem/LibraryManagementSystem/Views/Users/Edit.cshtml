@model LibraryManagementSystem.Models.User

@{
    ViewData["Title"] = "Update Member Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">Edit User Profile</h2>
        </div>

        <div class="tech-card border-top border-primary border-5">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                <input type="hidden" asp-for="UserId" />

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="FullName" class="form-label text-accent fw-bold"><i class="fas fa-signature me-1"></i> Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter full name" required />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="Role" class="form-label text-accent fw-bold"><i class="fas fa-user-tag me-1"></i> Account Role</label>
                            <select asp-for="Role" class="form-control" required>
                                <option value="User">Member/User</option>
                                <option value="Admin">Administrator</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="Username" class="form-label text-accent fw-bold"><i class="fas fa-at me-1"></i> Username</label>
                            <input asp-for="Username" class="form-control" placeholder="Choose username" required />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="Password" class="form-label text-accent fw-bold"><i class="fas fa-lock me-1"></i> Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Create password" required />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="Email" class="form-label text-accent fw-bold"><i class="fas fa-envelope me-1"></i> Email Address</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group">
                            <label asp-for="Phone" class="form-label text-accent fw-bold"><i class="fas fa-phone me-1"></i> Phone Number</label>
                            <input asp-for="Phone" class="form-control" placeholder="+123 456 789" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 pt-4 border-top border-tech mt-4">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        Update Profile
                    </button>
                    <a asp-action="Index" class="btn btn-outline-primary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
