@model LibraryManagementSystem.Models.User

@{
    ViewData["Title"] = "User Profile Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex align-items-center mb-4">
        <div class="d-flex align-items-center mb-5 border-bottom border-tech pb-4">
            <a asp-action="Index" class="btn btn-outline-primary border-0 me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h2 class="text-white mb-0">User Profile</h2>
        </div>

        <div class="tech-card border-top border-primary border-5">
            <div class="row">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <div class="bg-surface p-4 border border-tech d-inline-block shadow-sm">
                        <i class="fas fa-user-astronaut fa-6x text-primary"></i>
                    </div>
                    <div class="mt-3">
                        <span class="badge-tech @(Model.Role == "Admin" ? "badge-primary" : "border-tech") px-4 py-2">
                            Role: @Model.Role
                        </span>
                    </div>
                </div>
                <div class="col-md-8 border-start border-tech ps-md-5">
                    <label>Full Name</label>
                    <h3 class="text-white mb-1">@Model.FullName</h3>
                    <p class="text-muted small">User ID: @Model.UserId</p>

                    <div class="row g-4 mt-2">
                        <div class="col-sm-6">
                            <label>Email Address</label>
                            <span class="text-white d-block"><i class="fas fa-at text-primary me-2"></i>@Model.Email</span>
                        </div>
                        <div class="col-sm-6">
                            <label>Phone Number</label>
                            <span class="text-white d-block"><i class="fas fa-phone-alt text-primary me-2"></i>@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</span>
                        </div>
                        <div class="col-sm-12">
                            <label>Permissions</label>
                            <div class="d-flex gap-2 mt-2">
                                <span class="badge-tech border-primary text-primary"><i class="fas fa-key me-1"></i>System Access</span>
                                <span class="badge-tech border-tech"><i class="fas fa-database me-1"></i>Manage Catalog</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-5 pt-3 border-top border-tech">
                        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary flex-grow-1">
                            Edit Profile
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.UserId" class="btn btn-outline-danger">
                            <i class="fas fa-user-minus"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
