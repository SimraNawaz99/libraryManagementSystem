@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-5 mt-4">
    <div class="col-12">
        <h1 class="display-6 fw-bold text-white mb-2 text-glow">Welcome Back, <span class="text-primary">@User.FindFirst("FullName")?.Value</span></h1>
        <p class="text-muted opacity-75">Overview of your library and system management.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Stat Card 1 -->
    <div class="col-md-4">
        <div class="tech-card h-100">
            <div class="card-title">Books in Catalog</div>
            <div class="d-flex align-items-end mb-3">
                <div class="card-value">@ViewBag.TotalBooks</div>
                <div class="text-muted ms-3 pb-2 small">BOOKS</div>
            </div>
            <p class="text-muted small opacity-75"><i class="fas fa-book me-2"></i>Total library collection</p>
            <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary btn-sm w-100 mt-4">Manage Books</a>
        </div>
    </div>

    <!-- Stat Card 2 -->
    <div class="col-md-4">
        <div class="tech-card h-100">
            <div class="card-title">Active Members</div>
            <div class="d-flex align-items-end mb-3">
                <div class="card-value">@ViewBag.TotalUsers</div>
                <div class="text-muted ms-3 pb-2 small">USERS</div>
            </div>
            <p class="text-muted small opacity-75"><i class="fas fa-users me-2"></i>Registered library users</p>
            <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary btn-sm w-100 mt-4">View Members</a>
        </div>
    </div>

    <!-- Stat Card 3 -->
    <div class="col-md-4">
        <div class="tech-card h-100">
            <div class="card-title">Active Loans</div>
            <div class="d-flex align-items-end mb-3">
                <div class="card-value">@ViewBag.ActiveBorrows</div>
                <div class="text-muted ms-3 pb-2 small">LOANS</div>
            </div>
            <p class="text-muted small opacity-75"><i class="fas fa-exchange-alt me-2"></i>Currently borrowed books</p>
            <a asp-controller="BorrowRecords" asp-action="Index" class="btn btn-outline-primary btn-sm w-100 mt-4">Loans History</a>
        </div>
    </div>
</div>

<div class="action-strip mt-5">
    <a asp-controller="Books" asp-action="Create" class="action-btn-boxed">
        <i class="fas fa-plus-circle"></i>
        <span>Add New Asset</span>
    </a>
    <a asp-controller="BorrowRecords" asp-action="Create" class="action-btn-boxed">
        <i class="fas fa-book-reader"></i>
        <span>Issue Resource</span>
    </a>
    <a asp-controller="Users" asp-action="Create" class="action-btn-boxed">
        <i class="fas fa-user-plus"></i>
        <span>Enroll Member</span>
    </a>
</div>


<style>
    .ls-wide { letter-spacing: 0.1em; }
    .font-serif { font-family: 'Crimson Pro', serif; }
    .btn-outline-secondary { border: 2px solid var(--secondary); color: var(--secondary); font-weight: 600; }
    .btn-outline-secondary:hover { background: var(--secondary); color: white; }
</style>
